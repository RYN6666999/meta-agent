#!/usr/bin/env bash
# agent-switch — AI Agent SSH 存取開關
#
# 部署位置：/usr/local/bin/agent-switch（目標主機）
# 需以 agentbot 身份執行，或 sudo 執行（視部署方式而定）
#
# 用法：
#   agent-switch on      # 啟用：建立 enabled.flag，還原 authorized_keys
#   agent-switch off     # 停用：刪除 enabled.flag，停用 authorized_keys
#   agent-switch status  # 查看目前狀態（含 GATEWAY_MODE）
#   agent-switch mode <legacy-blacklist|audit|enforce|break-glass>
#                        # 切換 P7 命令治理模式
#
# Exit codes：
#   0 = 操作成功
#   1 = 參數錯誤或操作失敗

set -uo pipefail

# ── 設定 ─────────────────────────────────────────────────────────────

AGENT_HOME="/Users/agentbot"
SSH_DIR="${AGENT_HOME}/.ssh"
ENABLED_FLAG="${SSH_DIR}/enabled.flag"
AUTH_KEYS="${SSH_DIR}/authorized_keys"
AUTH_KEYS_DISABLED="${SSH_DIR}/authorized_keys.disabled"

# ── 輔助函式 ──────────────────────────────────────────────────────────

err() {
  echo "[agent-switch] ERROR: $*" >&2
  exit 1
}

check_ssh_dir() {
  if [[ ! -d "${SSH_DIR}" ]]; then
    err "${SSH_DIR} 不存在，請先建立 agentbot 帳號與 .ssh 目錄"
  fi
}

# P7：gateway-policy.sh 路徑
POLICY_FILE="$(dirname "$0")/gateway-policy.sh"

# ── 主邏輯 ───────────────────────────────────────────────────────────

CMD="${1:-}"

case "${CMD}" in

  on)
    check_ssh_dir
    # 還原 authorized_keys（若被停用）
    if [[ ! -f "${AUTH_KEYS}" && -f "${AUTH_KEYS_DISABLED}" ]]; then
      mv "${AUTH_KEYS_DISABLED}" "${AUTH_KEYS}" \
        || err "無法還原 authorized_keys"
      chmod 600 "${AUTH_KEYS}"
      echo "[agent-switch] authorized_keys 已還原"
    elif [[ -f "${AUTH_KEYS}" ]]; then
      echo "[agent-switch] authorized_keys 已存在，略過"
    else
      err "找不到 authorized_keys 或 authorized_keys.disabled，請先部署公鑰"
    fi

    # 建立 enabled.flag
    touch "${ENABLED_FLAG}" || err "無法建立 enabled.flag"
    chmod 600 "${ENABLED_FLAG}"
    echo "[agent-switch] ON — agent SSH 存取已啟用"
    ;;

  off)
    check_ssh_dir
    # 刪除 enabled.flag（gateway 立即拒絕後續命令）
    if [[ -f "${ENABLED_FLAG}" ]]; then
      rm -f "${ENABLED_FLAG}" || err "無法刪除 enabled.flag"
      echo "[agent-switch] enabled.flag 已刪除"
    else
      echo "[agent-switch] enabled.flag 不存在，略過"
    fi

    # 停用 authorized_keys（防止新連線建立）
    if [[ -f "${AUTH_KEYS}" ]]; then
      mv "${AUTH_KEYS}" "${AUTH_KEYS_DISABLED}" \
        || err "無法停用 authorized_keys"
      echo "[agent-switch] authorized_keys 已停用"
    else
      echo "[agent-switch] authorized_keys 不存在，略過"
    fi

    echo "[agent-switch] OFF — agent SSH 存取已停用"
    ;;

  mode)
    # P7：切換 GATEWAY_MODE
    NEW_MODE="${2:-}"
    case "${NEW_MODE}" in
      legacy-blacklist|audit|enforce|break-glass) ;;
      *)
        echo "用法: agent-switch mode <legacy-blacklist|audit|enforce|break-glass>" >&2
        exit 1
        ;;
    esac
    if [[ ! -f "${POLICY_FILE}" ]]; then
      err "gateway-policy.sh 不存在（${POLICY_FILE}），無法切換 mode"
    fi
    # 替換 GATEWAY_MODE= 那一行
    sed -i.bak "s/^GATEWAY_MODE=.*/GATEWAY_MODE=\"${NEW_MODE}\"/" "${POLICY_FILE}" \
      || err "無法更新 GATEWAY_MODE"
    rm -f "${POLICY_FILE}.bak"
    echo "[agent-switch] GATEWAY_MODE 已切換為：${NEW_MODE}"
    ;;

  status)
    echo "=== agent-switch 狀態 ==="

    # enabled.flag
    # 注意：/Users/agentbot/.ssh/ 是 drwx------，非 agentbot 身份可能無法讀取。
    # 以真實 SSH 測試結果為準，此處僅供參考。
    if [[ -f "${ENABLED_FLAG}" ]]; then
      echo "  Gateway 開關 : ON  (${ENABLED_FLAG} 存在)"
    else
      echo "  Gateway 開關 : UNKNOWN (${ENABLED_FLAG} 不可讀或不存在；以真實 SSH 測試確認)"
    fi

    # authorized_keys
    if [[ -f "${AUTH_KEYS}" ]]; then
      key_count=$(wc -l < "${AUTH_KEYS}" 2>/dev/null || echo "?")
      echo "  authorized_keys : 存在 (${key_count} 行)"
    else
      echo "  authorized_keys : 不存在"
    fi

    if [[ -f "${AUTH_KEYS_DISABLED}" ]]; then
      echo "  authorized_keys.disabled : 存在（SSH 已停用）"
    fi

    # Gateway mode（P7）
    if [[ -f "${POLICY_FILE}" ]]; then
      current_mode=$(grep '^GATEWAY_MODE=' "${POLICY_FILE}" | head -1 | sed 's/GATEWAY_MODE=//;s/"//g')
      echo "  Gateway Mode : ${current_mode:-unknown}"
    else
      echo "  Gateway Mode : legacy-blacklist（policy 檔不存在）"
    fi

    # 整體判斷
    echo ""
    if [[ -f "${ENABLED_FLAG}" && -f "${AUTH_KEYS}" ]]; then
      echo "  => 狀態：READY（可接受 agent 連線）"
    elif [[ ! -f "${ENABLED_FLAG}" ]]; then
      echo "  => 狀態：OFF（gateway 拒絕所有命令）"
    else
      echo "  => 狀態：PARTIAL（flag 存在但 authorized_keys 遺失）"
    fi
    ;;

  *)
    echo "用法: agent-switch <on|off|status|mode>" >&2
    echo "      agent-switch mode <legacy-blacklist|audit|enforce|break-glass>" >&2
    exit 1
    ;;

esac

exit 0
