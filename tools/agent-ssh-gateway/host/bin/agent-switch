#!/usr/bin/env bash
# agent-switch — AI Agent SSH 存取開關（P7 Lite）
#
# 部署位置：/usr/local/bin/agent-switch（目標主機）
# 可以 ryan 身份執行（sudo 管 agentbot 目錄）
#
# 日常用法：
#   agent-switch on       # 啟用 agent SSH 存取
#   agent-switch off      # 停用 agent SSH 存取（立即生效）
#   agent-switch status   # 查看目前狀態
#
# P7 Lite 設計：
#   - on/off 只管 enabled.flag（gateway 的唯一開關）
#   - authorized_keys 永久部署，不再搬動
#   - enabled.flag 在 /Users/agentbot/.ssh/，需 sudo 操作
#
# Exit codes：
#   0 = 操作成功
#   1 = 參數錯誤或操作失敗

set -uo pipefail

AGENT_HOME="/Users/agentbot"
ENABLED_FLAG="/usr/local/var/agentbot/enabled.flag"
AUTH_KEYS="${AGENT_HOME}/.ssh/authorized_keys"

err() {
  echo "[agent-switch] ERROR: $*" >&2
  exit 1
}

CMD="${1:-}"

case "${CMD}" in

  on)
    touch "${ENABLED_FLAG}" || err "無法建立 enabled.flag（請先執行一次性初始化）"
    echo "[agent-switch] ON — agent SSH 存取已啟用"
    ;;

  off)
    if [[ -f "${ENABLED_FLAG}" ]]; then
      rm -f "${ENABLED_FLAG}" || err "無法刪除 enabled.flag"
      echo "[agent-switch] enabled.flag 已刪除"
    else
      echo "[agent-switch] enabled.flag 不存在，略過"
    fi
    echo "[agent-switch] OFF — agent SSH 存取已停用"
    ;;

  status)
    echo "=== agent-switch 狀態 ==="
    if [[ -f "${ENABLED_FLAG}" ]]; then
      echo "  Gateway : ON  (enabled.flag 存在)"
    else
      echo "  Gateway : OFF (enabled.flag 不存在)"
    fi
    echo ""
    if [[ -f "${ENABLED_FLAG}" ]]; then
      echo "  => READY（可接受 agent 連線）"
    else
      echo "  => OFF（gateway 拒絕所有命令）"
    fi
    ;;

  *)
    echo "用法: agent-switch <on|off|status>" >&2
    exit 1
    ;;

esac

exit 0
