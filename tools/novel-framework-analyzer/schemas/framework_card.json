{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://novel-analyzer/schemas/framework_card.json",
  "title": "MvpSceneCard",
  "description": "局心欲變 MVP 場景分析卡 — 最小可用版本。四個維度均為純文字，原文引用為字串陣列。",
  "type": "object",
  "required": [
    "summary",
    "characters",
    "situation",
    "mind",
    "desire",
    "change",
    "change_intensity",
    "quotes"
  ],
  "properties": {
    "summary": {
      "type": "string",
      "maxLength": 300,
      "description": "場景摘要，200字以內"
    },
    "characters": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" },
      "description": "場景中所有出場角色，第一個為核心分析角色"
    },
    "is_negotiation": {
      "type": "boolean",
      "default": false,
      "description": "此場景是否為談判/博弈場景"
    },
    "negotiation_pattern_tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "談判模式標籤，is_negotiation=true 時填寫",
      "examples": ["借勢壓人", "以退為進", "資訊差建立優勢", "弱勢反拿主導權"]
    },
    "situation": {
      "type": "string",
      "description": "局：外部賽局結構。描述客觀環境、權力非對稱、誰主動推動、誰被迫應對、結構性約束。"
    },
    "mind": {
      "type": "string",
      "description": "心：此局在行動者身上形成的認知條件與盲區。分析順序：局 → 心。"
    },
    "desire": {
      "type": "string",
      "description": "欲：此局激活的顯性/隱性欲望與欲望衝突。局勢壓力召喚出的動機。"
    },
    "change": {
      "type": "string",
      "description": "變：觸發事件與局勢相變。描述變前→變後的局勢差異，必須引用原文觸發點。"
    },
    "change_intensity": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5,
      "description": "變的強度（1=微弱，3=中等，5=劇烈相變）"
    },
    "quotes": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" },
      "description": "支持分析的關鍵原文引用，必須直接複製原文，不得改寫或虛構"
    }
  },
  "_deferred": {
    "description": "以下欄位在 MVP 中延後，Phase 2+ 再啟用",
    "deferred_fields": [
      "confidence_score",
      "match_level",
      "mind_shift_type",
      "prompt_version",
      "schema_version",
      "hidden_goals",
      "fast_thinking",
      "slow_thinking",
      "before_state",
      "after_state",
      "trigger_event_structured",
      "leverage_source"
    ]
  }
}
