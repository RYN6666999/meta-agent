flowchart TD
    T[Trigger: scheduler or manual]
    F[Fact Collection]
    R[Rule Engine]
    D{Decision Type}
    A[Auto Execute]
    M[Manual Queue]
    S[Status and Reports]
    I[Iteration Hint]

    T --> F

    F --> F1[health_check status]
    F --> F2[e2e status]
    F --> F3[git diff facts]
    F --> F4[recent error logs]

    F1 --> R
    F2 --> R
    F3 --> R
    F4 --> R

    R --> D

    D -- auto_executable --> A
    D -- manual_required --> M

    A --> A1[truth-xval]
    A --> A2[reactivate_webhooks]
    A --> A3[git-score]

    A1 --> S
    A2 --> S
    A3 --> S
    M --> S

    S --> S1[memory/system-status.json]
    S --> S2[memory/decision-loop-last.json]
    S --> S3[memory/auto-decision-log.md]

    S --> I
    I --> T

    classDef core fill:#E8F5E9,stroke:#2E7D32,stroke-width:1px;
    classDef control fill:#E3F2FD,stroke:#1565C0,stroke-width:1px;
    classDef feedback fill:#FFF3E0,stroke:#EF6C00,stroke-width:1px;

    class T,F,R,D core;
    class A,M,S control;
    class I,S1,S2,S3 feedback;